{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": false,
    "noFallthroughCasesInSwitch": false,
    "types": [
      "jest",
      "node"
    ],
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@core": [
        "src/core"
      ],
      "@core/*": [
        "src/core/*"
      ],
      "@core/http": [
        "src/core/client-http"
      ],
      "@core/response": [
        "src/core/response"
      ],
      "@core/supabase": [
        "src/core/supabase"
      ],
      "@agent": [
        "src/agent"
      ],
      "@agent/*": [
        "src/agent/*"
      ],
      "@channels": [
        "src/channels"
      ],
      "@channels/*": [
        "src/channels/*"
      ],
      "@wecom": [
        "src/channels/wecom"
      ],
      "@wecom/*": [
        "src/channels/wecom/*"
      ],
      "@shared": [
        "src/shared"
      ],
      "@shared/*": [
        "src/shared/*"
      ],
      "@test-suite": [
        "src/biz/test-suite"
      ],
      "@test-suite/*": [
        "src/biz/test-suite/*"
      ],
      "@biz/*": [
        "src/biz/*"
      ],
      "@providers": [
        "src/providers"
      ],
      "@providers/*": [
        "src/providers/*"
      ],
      "@tools": [
        "src/tools"
      ],
      "@tools/*": [
        "src/tools/*"
      ],
      "@memory": [
        "src/memory"
      ],
      "@memory/*": [
        "src/memory/*"
      ],
      "@mcp": [
        "src/mcp"
      ],
      "@mcp/*": [
        "src/mcp/*"
      ],
      "@sponge": [
        "src/sponge"
      ],
      "@sponge/*": [
        "src/sponge/*"
      ],
      "@observability": [
        "src/observability"
      ],
      "@observability/*": [
        "src/observability/*"
      ],
      "@modelcontextprotocol/sdk/client": [
        "./node_modules/@modelcontextprotocol/sdk/dist/cjs/client/index"
      ],
      "@modelcontextprotocol/sdk/client/stdio": [
        "./node_modules/@modelcontextprotocol/sdk/dist/cjs/client/stdio"
      ],
      "@modelcontextprotocol/sdk/client/sse": [
        "./node_modules/@modelcontextprotocol/sdk/dist/cjs/client/sse"
      ],
      "@modelcontextprotocol/sdk/client/streamableHttp": [
        "./node_modules/@modelcontextprotocol/sdk/dist/cjs/client/streamableHttp"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "web"
  ]
}
