{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": false,
    "noFallthroughCasesInSwitch": false,
    "types": [
      "jest",
      "node"
    ],
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@infra/*": [
        "src/infra/*"
      ],
      "@agent/*": [
        "src/agent/*"
      ],
      "@channels": [
        "src/channels"
      ],
      "@channels/*": [
        "src/channels/*"
      ],
      "@wecom": [
        "src/channels/wecom"
      ],
      "@wecom/*": [
        "src/channels/wecom/*"
      ],
      "@enums/*": [
        "src/enums/*"
      ],
      "@test-suite/*": [
        "src/biz/test-suite/*"
      ],
      "@evaluation/*": [
        "src/evaluation/*"
      ],
      "@biz/*": [
        "src/biz/*"
      ],
      "@providers/*": [
        "src/providers/*"
      ],
      "@tools/*": [
        "src/tools/*"
      ],
      "@memory/*": [
        "src/memory/*"
      ],
      "@mcp/*": [
        "src/mcp/*"
      ],
      "@sponge/*": [
        "src/sponge/*"
      ],
      "@observability/*": [
        "src/observability/*"
      ],
      "@notification/*": [
        "src/notification/*"
      ],
      "@analytics/*": [
        "src/analytics/*"
      ],
      "@shared-types/*": [
        "src/types/*"
      ],
      "@modelcontextprotocol/sdk/client": [
        "./node_modules/@modelcontextprotocol/sdk/dist/cjs/client/index"
      ],
      "@modelcontextprotocol/sdk/client/stdio": [
        "./node_modules/@modelcontextprotocol/sdk/dist/cjs/client/stdio"
      ],
      "@modelcontextprotocol/sdk/client/sse": [
        "./node_modules/@modelcontextprotocol/sdk/dist/cjs/client/sse"
      ],
      "@modelcontextprotocol/sdk/client/streamableHttp": [
        "./node_modules/@modelcontextprotocol/sdk/dist/cjs/client/streamableHttp"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "web"
  ]
}
