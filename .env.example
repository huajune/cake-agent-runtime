# ================================
# DuLiDay 企业微信智能服务 - 环境变量配置
# ================================
# 注意：只保留需要用户配置的环境变量
# 其他配置使用合理的默认值，无需手动配置

# ================================
# 应用配置
# ================================
PORT=8080
NODE_ENV=development

# ================================
# AI Provider 配置（Vercel AI SDK 多 Provider 架构）
# ================================
# 原生 SDK Provider
ANTHROPIC_API_KEY=your-anthropic-key-here
DEEPSEEK_API_KEY=your-deepseek-key
GEMINI_API_KEY=your-gemini-key

# OpenAI-compatible Provider
DASHSCOPE_API_KEY=your-dashscope-key
MOONSHOT_API_KEY=your-moonshot-key
OPENROUTER_API_KEY=your-openrouter-key

# 代理 Provider (OpenAI / OhMyGPT 共享 ANTHROPIC_API_KEY，无需额外配置)
# OPENAI_BASE_URL=https://c-z0-api-01.hash070.com/v1
# OHMYGPT_BASE_URL=https://c-z0-api-01.hash070.com/v1

# AI 模型角色映射（必填）
AGENT_DEFAULT_MODEL=anthropic/claude-sonnet-4-5-20250929
AGENT_CHAT_MODEL=anthropic/claude-sonnet-4-5-20250929
AGENT_CLASSIFY_MODEL=openai/gpt-5-mini
AGENT_EXTRACT_MODEL=openai/gpt-5-mini
# AGENT_FAST_MODEL=deepseek/deepseek-chat
# AGENT_REASONING_MODEL=deepseek/deepseek-reasoner

# 角色降级链（逗号分隔，按需配置）
# AGENT_CHAT_FALLBACKS=deepseek/deepseek-chat,qwen/qwen-max-latest

# ================================
# Supabase 配置（必填）
# ================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ================================
# Redis 缓存配置（必填）
# ================================
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ================================
# DuLiDay API 配置（必填）
# ================================
DULIDAY_API_TOKEN=your-duliday-token-here

# ================================
# 托管平台 API 配置（必填）
# ================================
STRIDE_API_BASE_URL=https://stride-bg.dpclouds.com
STRIDE_ENTERPRISE_API_BASE_URL=https://stride-bg.dpclouds.com/hub-api

# ================================
# 飞书集成配置
# ================================
# 飞书开放平台应用凭证（飞书多维表格读写必填）
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 飞书告警机器人（可选）
# 启用飞书告警（默认 false）
ENABLE_FEISHU_ALERT=false
# 飞书机器人 Webhook URL
FEISHU_ALERT_WEBHOOK_URL=
# 飞书机器人签名密钥（可选）
FEISHU_ALERT_SECRET=

# ================================
# Bull 队列配置（可选，生产环境建议启用）
# ================================
# 启用 Bull 队列（默认 false，使用内存队列）
ENABLE_BULL_QUEUE=false
# Upstash Redis TCP 连接（启用 Bull 队列时必填）
# UPSTASH_REDIS_TCP_URL=rediss://default:password@your-redis.upstash.io:6379

# ================================
# 数据清理配置（可选，有默认值）
# ================================
# agent_invocation JSONB 字段保留天数，超出后置 NULL 释放空间（默认 7）
# DATA_CLEANUP_AGENT_INVOCATION_DAYS=7
# 消息处理记录保留天数（默认 14，历史数据已聚合到 hourly stats）
# DATA_CLEANUP_PROCESSING_DAYS=14
# 聊天消息保留天数（默认 60）
# DATA_CLEANUP_CHAT_DAYS=60
# 用户活跃记录保留天数（默认 35，覆盖 Dashboard 月度视图）
# DATA_CLEANUP_USER_ACTIVITY_DAYS=35
# 错误日志保留天数（默认 30）
# DATA_CLEANUP_ERROR_LOGS_DAYS=30
