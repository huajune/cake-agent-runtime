# ================================
# DuLiDay 企业微信智能服务 - 环境变量配置
# ================================
# 注意：只保留需要用户配置的环境变量
# 其他配置使用合理的默认值，无需手动配置

# ================================
# 应用配置
# ================================
PORT=8585
NODE_ENV=development

# 运行时环境标识；多个环境共用同一个 Upstash Redis 时用于隔离 key 与 Bull 队列前缀。
# 不设置则回退到 NODE_ENV，再回退 'development'。
# 推荐值：local / staging / production。本地启动**必须**设为非 production 值，
# 否则会消费生产 Bull Queue 消息（参见事故复盘 2026-04-20）。
RUNTIME_ENV=local

# ================================
# AI Provider 配置（Vercel AI SDK 多 Provider 架构）
# ================================
# 原生 SDK Provider
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_BASE_URL=https://c-z0-api-01.hash070.com/v1
DEEPSEEK_API_KEY=your-deepseek-key
GEMINI_API_KEY=your-gemini-key

# OpenAI-compatible Provider
DASHSCOPE_API_KEY=your-dashscope-key
MOONSHOT_API_KEY=your-moonshot-key
OPENROUTER_API_KEY=your-openrouter-key

# 代理 Provider (OpenAI 共享 ANTHROPIC_API_KEY)
OPENAI_BASE_URL=https://c-z0-api-01.hash070.com/v1

# AI 模型角色映射（必填）
AGENT_CHAT_MODEL=qwen/qwen3.7-plus
AGENT_EXTRACT_MODEL=deepseek/deepseek-v4-flash
AGENT_VISION_MODEL=qwen/qwen3.6-plus
AGENT_EVALUATE_MODEL=openai/gpt-5-mini
# 出站 LLM 守卫（llm 档）审查角色——开启 OUTPUT_GUARDRAIL_LLM_ENABLED 时必填，否则 review 角色解析失败会触发降级
# AGENT_REVIEW_MODEL=anthropic/claude-sonnet-4-6

# Extended Thinking（设为 >0 启用，推荐 10000~16000）
# AGENT_THINKING_BUDGET_TOKENS=10000

# 默认降级链（所有角色共享，逗号分隔；可用 AGENT_{ROLE}_FALLBACKS 覆盖特定角色）
# AGENT_DEFAULT_FALLBACKS=deepseek/deepseek-v4-flash,anthropic/claude-sonnet-4-6
# Vision 专用降级链（必须只含 multimodal 模型，否则降级后模型看不到图片会编造描述）
# AGENT_VISION_FALLBACKS=anthropic/claude-sonnet-4-6

# ================================
# 安全护栏配置（可选，有默认值）
# ================================
# 输出 token 上限（默认 4096）
# AGENT_MAX_OUTPUT_TOKENS=4096
# 输入消息总字符上限（默认 12000）
# AGENT_MAX_INPUT_CHARS=12000
# 出站 llm 档总开关（默认 false；true 时高风险回复触发 LlmReviewer，需同时配 AGENT_REVIEW_MODEL）
# OUTPUT_GUARDRAIL_LLM_ENABLED=false
# 会话 Redis 状态保留时长（默认 2 天；超时后 Redis facts/stage 自然过期）
# MEMORY_SESSION_TTL_DAYS=2
# 沉淀间隙阈值（默认 1 天；消息间隔超过此值触发会话沉淀，与 sessionTtl 独立）
# MEMORY_SETTLEMENT_GAP_DAYS=1
# Supabase 历史消息回查窗口（默认 7 天；与 sessionTtl 独立，跨天回来仍能看到历史）
# MEMORY_HISTORY_WINDOW_DAYS=7
# API 鉴权 Token（保护 /agent/*, /config/*, /test-suite/* 等端点；前端构建会自动复用此值）
API_GUARD_TOKEN=your-guard-token-here

# ================================
# Redis 缓存配置（Upstash - 必填）
# ================================
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ================================
# DuLiDay API 配置（必填）
# ================================
DULIDAY_API_TOKEN=your-duliday-token-here

# ================================
# 海绵工单 API（可选，有默认值）
# ================================
# 工单查询走 ${SPONGE_API_BASE_URL}/ai/api/workorder/signup/list（Header: Duliday-Token）
# SPONGE_API_BASE_URL=https://gateway.duliday.com/sponge

# 海绵按托管账号映射的 Duliday-Token。
# system_config.sponge_token_config 里各账号用 tokenEnv 指向下列环境变量名，
# 真实 token 只放在环境变量里，不入库、不进 git。未配置则回退 DULIDAY_API_TOKEN。
# SPONGE_TOKEN_ZHUDONGSHENG=
# SPONGE_TOKEN_LIHANTING=
# SPONGE_TOKEN_LIYUHANG=
# SPONGE_TOKEN_GAOYAQI=
# SPONGE_TOKEN_PANPAN=

# ================================
# 运营日报飞书 cron（生产默认写飞书，可显式关闭）
# ================================
# 每天 21:00(Asia/Shanghai) 把当天数据写入飞书「运营日报」多维表格。
# 成功报名数 / 通过数 / 候选人基本信息会按托管账号 Duliday-Token 从海绵 self/list 覆盖。
# 如需本地 dry-run，可显式置 false。
# FEISHU_OPS_REPORT_ENABLED=true
# app_token / table_id 默认指向「运营日报」表，按需覆盖
# FEISHU_OPS_REPORT_APP_TOKEN=TM0hb4fmtaa5jusAnlnc32Nfnpg
# FEISHU_OPS_REPORT_TABLE_ID=tblusTgxaBKp9BA7

# ================================
# 花卷招聘事件上报（可选；缺 token 时静默跳过，不阻塞）
# ================================
# POST {HUAJUNE_API_BASE_URL}/api/v1/recruitment-events（Authorization: Bearer HUAJUNE_API_TOKEN）
# HUAJUNE_API_BASE_URL=https://huajune.duliday.com
# HUAJUNE_API_TOKEN=your-huajune-open-api-token
# sourcePlatform 取值仅 zhipin|yupao|duliday（"cake" 身份在 agentId 上），默认 duliday
# HUAJUNE_SOURCE_PLATFORM=duliday

# ================================
# 托管平台 API 配置（必填）
# ================================
STRIDE_API_BASE_URL=https://stride-bg.dpclouds.com
STRIDE_ENTERPRISE_API_BASE_URL=https://stride-bg.dpclouds.com/hub-api
# 企业级 /group/list 代理接口使用的服务端 token
STRIDE_ENTERPRISE_TOKEN=your-enterprise-token-here

# ================================
# Bull 队列配置（可选，生产环境建议启用）
# ================================
# 启用 Bull 队列（默认 false，使用内存队列）
ENABLE_BULL_QUEUE=false
# Upstash Redis TCP 连接（启用 Bull 队列时必填）
# UPSTASH_REDIS_TCP_URL=rediss://default:password@your-redis.upstash.io:6379

# Test Suite 执行并发（本地全量验证可临时调大，注意模型/API 限流）
TEST_SUITE_WORKER_CONCURRENCY=20
TEST_SUITE_BATCH_CONCURRENCY=20
TEST_SUITE_CONVERSATION_CONCURRENCY=20
TEST_SUITE_JOB_TIMEOUT_MS=180000

# ================================
# 飞书集成配置
# ================================
# 飞书开放平台应用凭证（飞书多维表格读写必填）
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 飞书多维表格配置（按表拆分，避免把 appToken/tableId 硬编码到源码）
FEISHU_BITABLE_CHAT_APP_TOKEN=
FEISHU_BITABLE_CHAT_TABLE_ID=
FEISHU_BITABLE_BADCASE_APP_TOKEN=
FEISHU_BITABLE_BADCASE_TABLE_ID=
FEISHU_BITABLE_GOODCASE_APP_TOKEN=
FEISHU_BITABLE_GOODCASE_TABLE_ID=
FEISHU_BITABLE_TEST_SUITE_APP_TOKEN=
FEISHU_BITABLE_TEST_SUITE_TABLE_ID=
FEISHU_BITABLE_VALIDATION_SET_APP_TOKEN=
FEISHU_BITABLE_VALIDATION_SET_TABLE_ID=
FEISHU_BITABLE_ASSET_RELATION_APP_TOKEN=
FEISHU_BITABLE_ASSET_RELATION_TABLE_ID=

# 飞书告警机器人
FEISHU_ALERT_WEBHOOK_URL=
FEISHU_ALERT_SECRET=
# 开发/测试环境若也要发送飞书系统告警，显式打开
# FEISHU_ALERT_ALLOW_NON_PROD=false

# 飞书消息通知群机器人
MESSAGE_NOTIFICATION_WEBHOOK_URL=
MESSAGE_NOTIFICATION_WEBHOOK_SECRET=

# 飞书私聊/企微私域监控群机器人（面试预约、发版通知等）
PRIVATE_CHAT_MONITOR_WEBHOOK_URL=
PRIVATE_CHAT_MONITOR_WEBHOOK_SECRET=

# 告警忽略 IP 列表（逗号分隔，可选）
# FEISHU_ALERT_IGNORED_IPS=

# ================================
# 高德地图 API（地理编码，必填）
# ================================
AMAP_API_KEY=

# ================================
# Supabase 配置（必填）
# ================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_BUCKET_NAME=Bot
SUPABASE_BRAND_CONFIG_PATH=configData/AppConfig.json

# 数据库直连 URL（用于 supabase db push / migration list）
# 格式: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
SUPABASE_DB_URL_TEST=postgresql://postgres:[YOUR-DB-PASSWORD]@db.gaovfitvetoojkvtalxy.supabase.co:5432/postgres
SUPABASE_DB_URL_PROD=postgresql://postgres:[YOUR-DB-PASSWORD]@db.uvmbxcilpteaiizplcyp.supabase.co:5432/postgres

# ================================
# 数据清理配置（可选，有默认值）
# ================================
# agent_invocation JSONB 字段保留天数，超出后置 NULL 释放空间（默认 7）
# DATA_CLEANUP_AGENT_INVOCATION_DAYS=7
# 消息处理记录保留天数（默认 30，历史数据已聚合到 hourly stats）
# DATA_CLEANUP_PROCESSING_DAYS=30
# 聊天消息保留天数（默认 60）
# DATA_CLEANUP_CHAT_DAYS=60
# 用户活跃记录保留天数（默认 365，覆盖用户趋势 30/90/180 天视图）
# DATA_CLEANUP_USER_ACTIVITY_DAYS=365
# 错误日志保留天数（默认 30）
# DATA_CLEANUP_ERROR_LOGS_DAYS=30

# ================================
# 优雅停机（可选，有默认值）
# ================================
# 发版 SIGTERM 后等待 in-flight 消息处理完成的最长时间（默认 60000ms）
# 应小于部署平台的强杀（SIGKILL）宽限期
# SHUTDOWN_DRAIN_TIMEOUT_MS=60000

# ================================
# 群任务定时通知（可选）
# ================================
# 总开关（默认 false，开启后才会执行定时任务）
# ENABLE_GROUP_TASK=false
# 试运行模式（默认 true，消息发飞书预览而非企微群）
# GROUP_TASK_DRY_RUN=true
# 小组名称:token 逗号分隔（必填，否则群任务无法获取群列表）
# GROUP_TASK_TOKENS=艾酱:token1,宇航:token2,南瓜:token3,琪琪:token4
# 拉群工具专用查群源；不配置时回退 GROUP_TASK_TOKENS。生产建议只配琪琪账号。
# INVITE_GROUP_SOURCE_TOKENS=琪琪:token4
# 观远BI 登录账号
# GUANYUAN_LOGIN_ID=
# 观远BI 登录密码（Base64 格式，API 原样发送）
# GUANYUAN_PASSWORD=
# 观远BI 数据源刷新 Token
# GUANYUAN_REFRESH_TOKEN=
# 观远BI 刷新后等待时间（默认 35000ms）
# GUANYUAN_BI_REFRESH_WAIT_MS=35000
# 群任务发送基础间隔（默认 120000ms，实际会做人类化随机抖动 1.5~3x）
# GROUP_TASK_SEND_DELAY_MS=120000
# 微信小程序配置（兼职群发送小程序卡片，必填）
MINIPROGRAM_APPID=
MINIPROGRAM_USERNAME=
# MINIPROGRAM_THUMB_URL=

# === 复聊 / reengagement 总开关 ===
# =false 时 scheduler 不入队任何 job，复聊不启动（默认代码值为 true，建议显式配置）。
REENGAGEMENT_ENABLED=false
# 真发保护：默认 shadow（只排程不投递）。
# REENGAGEMENT_SHADOW=true
