{
  "name": "cake-agent-runtime",
  "version": "5.3.0",
  "description": "自主 AI Agent 运行时 — 基于 Vercel AI SDK 多 Provider 架构",
  "author": "",
  "private": true,
  "license": "ISC",
  "scripts": {
    "build": "nest build",
    "build:ci": "API_GUARD_TOKEN=ci-placeholder-token pnpm run build:web && API_GUARD_TOKEN=ci-placeholder-token pnpm run build",
    "build:web": "cd web && pnpm run build",
    "ci:check": "pnpm run lint:check && pnpm run format:check && pnpm run typecheck && pnpm run build:ci && pnpm run test:ci",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "lint:check": "eslint \"src/**/*.ts\" --max-warnings=0",
    "start:dev": "pnpm run build:web && nest start --watch",
    "start:prod": "node dist/main",
    "web:dev": "cd web && pnpm run dev",
    "install:all": "pnpm install --ignore-scripts && cd web && pnpm install",
    "test": "jest",
    "test:ci": "jest --coverage --watchman=false",
    "test:cov": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "db:pull": "supabase db pull",
    "db:push:test": "dotenv -e .env.local -- bash -c 'supabase db push --db-url $SUPABASE_DB_URL_TEST'",
    "db:push:prod": "dotenv -e .env.local -- bash -c 'supabase db push --db-url $SUPABASE_DB_URL_PROD'",
    "db:diff": "supabase db diff",
    "db:status": "supabase migration list",
    "db:status:test": "dotenv -e .env.local -- bash -c 'supabase migration list --db-url $SUPABASE_DB_URL_TEST'",
    "db:status:prod": "dotenv -e .env.local -- bash -c 'supabase migration list --db-url $SUPABASE_DB_URL_PROD'",
    "db:new": "supabase migration new",
    "sync:test-suite:prod": "node scripts/sync-test-suite-batches-to-prod.js",
    "release:pr:preview": "node scripts/build-release-pr-body.js --stdout",
    "release:pr:create": "node scripts/create-release-pr.js",
    "deploy": "bash scripts/deploy-local.sh"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/deepseek": "^2.0.24",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/swagger": "^7.1.17",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@supabase/supabase-js": "^2.99.0",
    "@upstash/redis": "^1.35.6",
    "ai": "^6.0.38",
    "axios": "^1.6.2",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "crypto": "^1.0.1",
    "ioredis": "^5.8.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "nodejieba",
      "supabase"
    ]
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.1",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.3.0",
    "@types/bull": "^4.10.4",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "source-map-support": "^0.5.21",
    "supabase": "^2.77.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
