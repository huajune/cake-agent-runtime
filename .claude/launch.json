{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "start:dev"],
      "port": 8080,
      "autoPort": false
    },
    {
      "name": "web",
      "runtimeExecutable": "bash",
      "runtimeArgs": [
        "-c",
        "unset PORT; VITE_API_PROXY_TARGET=http://localhost:8080 pnpm --dir web run dev"
      ],
      "port": 5175,
      "autoPort": false
    }
  ]
}
